[alias]
	co = checkout
	br = branch
	ci = commit
	st = status
[pull]
	rebase = true
[init]
	defaultBranch = master
[user]
	name = Sebastian Arrieta
  signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIDkuymYKRki3WROwOVB7PhfepB8T9Sk+cbEeNf0HWXhp
	email = 25210925+sarrietav-dev@users.noreply.github.com
[include]
  path = ~/.dotfiles/git/themes.gitconfig
[delta]
  syntax-theme = gruvbox-dark
[core]
	pager = delta
[gpg]
  format = ssh
[gpg "ssh"]
	program = /usr/bin/ssh-keygen
[commit]
  gpgsign = true
[credential]
	helper = gh
[include]
  path = ~/.config/omarchy/current/theme/delta.gitconfig
[rebase]
	updateRefs = true
