#!/bin/bash
# omarchy:summary=Regenerate and apply Vicinae's theme to match Omarchy's currently active theme
#
# Reads ~/.config/omarchy/current/theme/colors.toml (Omarchy's normalized per-theme
# color set) and writes a matching theme file for Vicinae at
# ~/.local/share/vicinae/themes/omarchy.toml, then applies it.
#
# Run this again any time you switch Omarchy themes (omarchy-theme-set).

set -euo pipefail

THEME_DIR="$HOME/.config/omarchy/current/theme"
COLORS_FILE="$THEME_DIR/colors.toml"
OUT_DIR="$HOME/.local/share/vicinae/themes"
OUT_FILE="$OUT_DIR/omarchy.toml"

if [[ ! -f $COLORS_FILE ]]; then
  echo "No colors.toml found at $COLORS_FILE -- is an Omarchy theme active?" >&2
  exit 1
fi

get() {
  grep -E "^$1[[:space:]]*=" "$COLORS_FILE" | head -1 | sed -E 's/^[a-zA-Z0-9_]+[[:space:]]*=[[:space:]]*"(.*)"/\1/'
}

accent=$(get accent)
foreground=$(get foreground)
background=$(get background)
selection_background=$(get selection_background)
selection_foreground=$(get selection_foreground)
black=$(get color0)
red=$(get color1)
green=$(get color2)
yellow=$(get color3)
blue=$(get color4)
magenta=$(get color5)
cyan=$(get color6)
white=$(get color7)

for name in accent foreground background black red green yellow blue magenta cyan white; do
  if [[ -z ${!name} ]]; then
    echo "Failed to parse '$name' from $COLORS_FILE -- refusing to write a broken theme" >&2
    exit 1
  fi
done

variant="dark"
[[ -f $THEME_DIR/light.mode ]] && variant="light"

theme_name=$(omarchy-theme-current)

mkdir -p "$OUT_DIR"
cat >"$OUT_FILE" <<EOF
# Auto-generated by omarchy-sync-vicinae-theme -- do not edit by hand,
# it will be overwritten the next time you switch Omarchy themes.

[meta]
name = "Omarchy ($theme_name)"
description = "Synced from Omarchy's active theme"
variant = "$variant"
inherits = "vicinae-$variant"

[colors.core]
accent = "$accent"
background = "$background"
foreground = "$foreground"
secondary_background = "$black"
border = "$white"

[colors.accents]
blue = "$blue"
green = "$green"
magenta = "$magenta"
orange = "$yellow"
purple = "$magenta"
red = "$red"
yellow = "$yellow"
cyan = "$cyan"

# Omarchy's selection_background/foreground are chosen for highlighting a
# span of terminal text, which is often deliberately vivid (e.g. Catppuccin's
# cream or Gruvbox's bright orange). That's the right place for them: actual
# text selection. It's the wrong color for a full list-row background fill,
# which is why secondary_background above uses color0 (a muted panel tone)
# instead -- Vicinae's list/grid selection highlight derives from it.
[colors.text.selection]
background = "$selection_background"
foreground = "$selection_foreground"
EOF

vicinae theme set omarchy
echo "Vicinae theme synced to Omarchy's \"$theme_name\" ($variant)."
